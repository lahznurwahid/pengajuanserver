{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "jest",
      "@testing-library/jest-dom",
      "node",
      "@testing-library/react"
    ],
    "isolatedModules": true,
    "noEmit": true,
    "module": "commonjs",
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "include": [
    "test/**/*",
    "jest.setup.ts",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "app"
  ]
}